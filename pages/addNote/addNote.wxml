<view class="container">
  <view class="form">
    <input class="title-input" placeholder="标题（可选）" value="{{title}}" bindinput="onTitleInput" />
    
    <!-- Markdown Toolbar -->
    <view class="markdown-toolbar">
      <text class="tool-btn" bindtap="insertBold">B</text>
      <text class="tool-btn italic" bindtap="insertItalic">I</text>
      <text class="tool-btn" bindtap="insertHeading">H</text>
      <text class="tool-btn" bindtap="insertList">☰</text>
      <text class="tool-btn" bindtap="insertOrderedList">1.</text>
      <text class="tool-btn" bindtap="insertCode">{ }</text>
      <text class="tool-btn" bindtap="uploadImage">🖼️</text>
    </view>
    
    <editor id="contentEditor" class="content-input" placeholder="支持 Markdown 语法..." bindinput="onEditorInput" bindready="onEditorReady" maxlength="5000" />
    <text class="word-count">{{content.length}}/5000</text>
  </view>

  <view class="color-picker">
    <text class="label">背景颜色</text>
    <view class="colors">
      <view class="color-item {{color === '#ffffff' ? 'active' : ''}}" style="background: #ffffff; border: 1rpx solid #ddd;" bindtap="selectColor" data-color="#ffffff"></view>
      <view class="color-item {{color === '#FFF9C4' ? 'active' : ''}}" style="background: #FFF9C4;" bindtap="selectColor" data-color="#FFF9C4"></view>
      <view class="color-item {{color === '#C8E6C9' ? 'active' : ''}}" style="background: #C8E6C9;" bindtap="selectColor" data-color="#C8E6C9"></view>
      <view class="color-item {{color === '#BBDEFB' ? 'active' : ''}}" style="background: #BBDEFB;" bindtap="selectColor" data-color="#BBDEFB"></view>
      <view class="color-item {{color === '#FFCCBC' ? 'active' : ''}}" style="background: #FFCCBC;" bindtap="selectColor" data-color="#FFCCBC"></view>
      <view class="color-item {{color === '#E1BEE7' ? 'active' : ''}}" style="background: #E1BEE7;" bindtap="selectColor" data-color="#E1BEE7"></view>
    </view>
  </view>

  <view class="preview" style="background: {{color}};">
    <text class="preview-title">{{title || '预览标题'}}</text>
    <view class="preview-content-wrapper">
      <block wx:for="{{parsedContent}}" wx:for-item="segment" wx:key="index">
        <!-- Line breaks -->
        <view wx:if="{{segment.type === 'br'}}" class="preview-br"></view>
        
        <!-- Headings -->
        <view wx:if="{{segment.type === 'heading'}}" class="preview-heading preview-heading-{{segment.level}}">
          <block wx:for="{{segment.content}}" wx:for-item="inline" wx:key="idx">
            <text wx:if="{{inline.type === 'text'}}" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'bold'}}" class="preview-bold" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'italic'}}" class="preview-italic" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'code'}}" class="preview-inline-code">{{inline.content}}</text>
            <text wx:if="{{inline.type === 'link'}}" class="preview-link" bindtap="openLink" data-url="{{inline.content}}">{{inline.content}}</text>
            <image wx:if="{{inline.type === 'image'}}" class="preview-inline-image" src="{{tempImageUrl || inline.src}}" mode="aspectFill" binderror="onPreviewImageError" bindtap="previewImage" data-src="{{inline.src}}"></image>
          </block>
        </view>
        
        <!-- List items -->
        <view wx:if="{{segment.type === 'list-item'}}" class="preview-list-item">
          <text wx:if="{{segment.listType === 'unordered'}}" class="preview-bullet">• </text>
          <text wx:if="{{segment.listType === 'ordered'}}" class="preview-number">{{segment.number}}. </text>
          <block wx:for="{{segment.content}}" wx:for-item="inline" wx:key="idx">
            <text wx:if="{{inline.type === 'text'}}" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'bold'}}" class="preview-bold" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'italic'}}" class="preview-italic" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'code'}}" class="preview-inline-code">{{inline.content}}</text>
            <text wx:if="{{inline.type === 'link'}}" class="preview-link" bindtap="openLink" data-url="{{inline.content}}">{{inline.content}}</text>
            <image wx:if="{{inline.type === 'image'}}" class="preview-inline-image" src="{{tempImageUrl || inline.src}}" mode="aspectFill" binderror="onPreviewImageError" bindtap="previewImage" data-src="{{inline.src}}"></image>
          </block>
        </view>
        
        <!-- Paragraphs -->
        <view wx:if="{{segment.type === 'paragraph'}}" class="preview-paragraph">
          <block wx:for="{{segment.content}}" wx:for-item="inline" wx:key="idx">
            <text wx:if="{{inline.type === 'text'}}" class="preview-text" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'bold'}}" class="preview-bold" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'italic'}}" class="preview-italic" user-select>{{inline.content}}</text>
            <text wx:if="{{inline.type === 'code'}}" class="preview-inline-code">{{inline.content}}</text>
            <text wx:if="{{inline.type === 'link'}}" class="preview-link" bindtap="openLink" data-url="{{inline.content}}">{{inline.content}}</text>
            <image wx:if="{{inline.type === 'image'}}" class="preview-image" src="{{tempImageUrl || inline.src}}" mode="aspectFill" binderror="onPreviewImageError" bindtap="previewImage" data-src="{{inline.src}}"></image>
          </block>
        </view>
      </block>
      <text wx:if="{{!parsedContent || parsedContent.length === 0}}" class="preview-placeholder">预览内容...</text>
    </view>
  </view>
</view>

<view class="footer">
  <button class="btn-save" bindtap="saveNote">保存</button>
</view>
