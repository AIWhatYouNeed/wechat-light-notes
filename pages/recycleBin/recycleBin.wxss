.container {
  padding: 30rpx;
  padding-bottom: 140rpx;
  background: #F8F8F8;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #666;
  background: #f5f5f5;
}

.tab.active {
  background: #667eea;
  color: #fff;
  font-weight: bold;
}

/* Section */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* Item List */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.todo-item {
  background: #fff;
  border-left: 8rpx solid #667eea;
}

.item-content {
  margin-bottom: 16rpx;
}

.item-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.item-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-group {
  display: block;
  font-size: 24rpx;
  color: #667eea;
  margin-bottom: 8rpx;
}

.item-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.item-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.restore-btn {
  padding: 12rpx 30rpx;
  background: #e8f5e9;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #4caf50;
}

.delete-btn {
  padding: 12rpx 30rpx;
  background: #ffebee;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #f44336;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* Footer Actions */
.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.footer-row {
  display: flex;
  gap: 20rpx;
}

.btn-clear-expired {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff9800;
  color: #fff;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-clear-expired::after {
  border: none;
}

.btn-clear-all {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f44336;
  color: #fff;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-clear-all::after {
  border: none;
}
