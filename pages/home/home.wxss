.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F8F8F8;
}

/* Sticky Header */
.sticky-header {
  flex-shrink: 0;
  background: #F8F8F8;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: calc(40rpx + env(safe-area-inset-top)) 30rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* Scrollable Content */
.content-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 30rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 20rpx;
}

.nickname {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.header-actions {
  display: flex;
  gap: 16rpx;
  margin-right: 180rpx;
  margin-top: 40rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
  font-size: 20rpx;
}

.action-btn .icon {
  font-size: 32rpx;
  margin-bottom: 2rpx;
}

/* Quick Add */
.quick-add {
  margin: 20rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.quick-add .icon {
  font-size: 48rpx;
  color: #667eea;
  margin-right: 20rpx;
}

.quick-add text:last-child {
  font-size: 28rpx;
  color: #999;
}

/* Section */
.section {
  margin: 0 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #667eea;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-icon {
  font-size: 28rpx;
  color: #667eea;
  margin-right: 20rpx;
  font-weight: bold;
}

.title-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.batch-trigger {
  font-size: 24rpx;
  color: #667eea;
  padding: 6rpx 16rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
}

/* Note List */
.note-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.note-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.note-content {
  margin-bottom: 20rpx;
}

.note-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.note-preview-wrapper {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  max-height: 3.2em;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.note-preview {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
}

.note-preview.link {
  color: #576b95;
  text-decoration: underline;
  word-break: break-all;
}

.note-time {
  font-size: 24rpx;
  color: #999;
}

.note-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.share-tag {
  padding: 0 20rpx;
  height: 56rpx;
  background: #f0f0f0;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 56rpx;
  text-align: center;
  white-space: nowrap;
  display: inline-block;
}

.share-tag.shared {
  background: #e8f5e9;
  color: #4caf50;
}

.delete-btn {
  padding: 0 20rpx;
  height: 56rpx;
  background: #ffebee;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #f44336;
  line-height: 56rpx;
  text-align: center;
  white-space: nowrap;
  display: inline-block;
}

/* Todo List */
.todo-input-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.todo-input {
  flex: 1;
  height: 60rpx;
  font-size: 30rpx;
  color: #333;
}

.todo-add-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.todo-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-item.completed .todo-text {
  text-decoration: line-through;
  color: #999;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.checkbox.checked {
  background: #4caf50;
  border-color: #4caf50;
}

.todo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.todo-text-wrapper {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  max-height: 2.4em;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.todo-text {
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
}

.todo-text.link {
  color: #576b95;
  text-decoration: underline;
  word-break: break-all;
}

.todo-time {
  font-size: 24rpx;
  color: #999;
}

.todo-delete {
  padding: 8rpx 20rpx;
  background: #ffebee;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #f44336;
  margin-left: 20rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
  opacity: 0;
  transition: opacity 0.3s;
}

.modal.show {
  display: flex;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  margin: auto;
  transform: scale(0.9);
  width: 80%;
  background: #fff;
  border-radius: 20rpx;
  transition: transform 0.3s;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  padding: 40rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-body {
  padding: 40rpx;
}

.modal-body input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer button {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  background: none;
  border: none;
  font-size: 32rpx;
}

.modal-footer button::after {
  border: none;
}

.btn-cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #667eea;
  font-weight: bold;
}

/* Batch Delete Bar */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.batch-info {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.batch-actions {
  display: flex;
  gap: 20rpx;
}

.batch-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 24rpx;
}

.batch-btn.delete {
  color: #f44336;
  background: #ffebee;
}

.batch-btn.cancel {
  color: #666;
  background: #f5f5f5;
}

/* Batch Checkbox */
.batch-checkbox {
  margin-right: 20rpx;
}

.batch-checkbox .checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.batch-checkbox .checkbox.checked {
  background: #667eea;
  border-color: #667eea;
}

.batch-checkbox .checkbox text {
  color: #fff;
  font-size: 28rpx;
}

.batch-item {
  display: flex;
  align-items: center;
}

.note-item.selected,
.todo-item.selected {
  background: #f0f7ff !important;
}

.note-item.selected .batch-checkbox .checkbox,
.todo-item.selected .batch-checkbox .checkbox {
  background: #667eea;
  border-color: #667eea;
}
