<view class="container">
  <!-- Sticky Header -->
  <view class="sticky-header">
    <!-- Header -->
    <view class="header">
      <view class="user-info" bindtap="goToMine">
        <image class="avatar" src="{{userInfo.avatarUrl || '/static/icon/headPortrait.png'}}" mode="aspectFill" binderror="onAvatarError"></image>
        <text class="nickname">{{userInfo.nickName || '用户'}}</text>
      </view>
      <view class="header-actions">
        <view class="action-btn" bindtap="goToGroups">
          <text class="icon">👥</text>
          <text>共享组</text>
        </view>
        <view class="action-btn" bindtap="goToShare">
          <text class="icon">📤</text>
          <text>查看分享</text>
        </view>
      </view>
    </view>

    <!-- Quick Add -->
    <view class="quick-add" bindtap="onAddNote">
      <text class="icon">+</text>
      <text>记录新的小记...</text>
    </view>
  </view>

  <!-- Scrollable Content -->
  <scroll-view class="content-scroll" scroll-y="true">
    <!-- Notes List -->
    <view class="section">
      <!-- Notes Batch Bar -->
      <view class="batch-bar" wx:if="{{notesBatchMode}}">
        <text class="batch-info">已选择 {{selectedNotes.length}} 项</text>
        <view class="batch-actions">
          <text class="batch-btn" bindtap="selectAllNotes">全选</text>
          <text class="batch-btn delete" bindtap="batchDeleteNotes">删除</text>
          <text class="batch-btn cancel" bindtap="exitNotesBatchMode">取消</text>
        </view>
      </view>

      <view class="section-title" bindtap="{{notesBatchMode ? '' : 'toggleNotes'}}">
        <text>我的小记</text>
        <view class="title-actions" wx:if="{{!notesBatchMode}}">
          <text class="batch-trigger" catchtap="enterNotesBatchMode">批量</text>
          <text class="toggle-icon">{{notesCollapsed ? '▶' : '▼'}}</text>
        </view>
      </view>
      <block wx:if="{{!notesCollapsed && notes.length > 0}}">
        <view class="note-list">
          <view wx:for="{{notes}}" wx:key="_id" class="note-item {{notesBatchMode ? 'batch-item' : ''}} {{item.selected ? 'selected' : ''}}" bindtap="{{notesBatchMode ? 'toggleNoteSelect' : 'previewNote'}}" data-note="{{item}}" data-id="{{item._id}}">
            <view class="batch-checkbox" wx:if="{{notesBatchMode}}">
              <view class="checkbox {{item.selected ? 'checked' : ''}}">
                <text wx:if="{{item.selected}}">✓</text>
              </view>
            </view>
            <view class="note-content">
              <text class="note-title">{{item.title || '无标题'}}</text>
              <view class="note-preview-wrapper {{item.content.length > 100 ? 'collapsed' : ''}}">
                <view class="note-preview-inner">
                  <block wx:for="{{item.contentSegments}}" wx:for-item="segment" wx:key="index">
                    <text wx:if="{{segment.type === 'text'}}" class="note-preview">{{segment.content}}</text>
                    <text wx:if="{{segment.type === 'link'}}" class="note-preview link" bindtap="openLink" data-url="{{segment.content}}">{{segment.content}}</text>
                  </block>
                </view>
              </view>
              <view class="note-expand-hint" wx:if="{{item.content.length > 100}}">点击查看详情</view>
              <text class="note-time">{{item.createTime}}</text>
            </view>
            <view class="note-actions" catchtap="stopPropagation" wx:if="{{!notesBatchMode}}">
              <text class="share-tag {{item.shared ? 'shared' : ''}}" bindtap="toggleShare" data-item="{{item}}" data-index="{{index}}">{{item.shared ? '已分享' : '分享'}}</text>
              <text class="delete-btn" bindtap="onDeleteNote" data-id="{{item._id}}">删除</text>
            </view>
          </view>
        </view>
      </block>
      <view wx:if="{{!notesCollapsed && notes.length === 0}}" class="empty-state">
        <image src="/static/icon/empty_fill.png" mode="aspectFit"></image>
        <text>还没有小记，点击上方添加</text>
      </view>
    </view>

    <!-- Todo List -->
    <view class="section">
      <!-- Todos Batch Bar -->
      <view class="batch-bar" wx:if="{{todosBatchMode}}">
        <text class="batch-info">已选择 {{selectedTodos.length}} 项</text>
        <view class="batch-actions">
          <text class="batch-btn" bindtap="selectAllTodos">全选</text>
          <text class="batch-btn delete" bindtap="batchDeleteTodos">删除</text>
          <text class="batch-btn cancel" bindtap="exitTodosBatchMode">取消</text>
        </view>
      </view>

      <view class="section-title" bindtap="{{todosBatchMode ? '' : 'toggleTodos'}}">
        <text>待办事项</text>
        <view class="title-actions" wx:if="{{!todosBatchMode}}">
          <text class="batch-trigger" catchtap="enterTodosBatchMode">批量</text>
          <text class="toggle-icon">{{todosCollapsed ? '▶' : '▼'}}</text>
        </view>
      </view>
      <block wx:if="{{!todosCollapsed && !todosBatchMode}}">
        <view class="todo-input-box">
          <input class="todo-input" placeholder="添加新的待办事项..." value="{{newTodo}}" bindinput="onTodoInput" confirm-type="done" bindconfirm="addTodo" />
          <view class="todo-add-btn" bindtap="addTodo">+</view>
        </view>
      </block>
      <block wx:if="{{!todosCollapsed && todos.length > 0}}">
        <view class="todo-list">
          <view wx:for="{{todos}}" wx:key="_id" class="todo-item {{item.completed ? 'completed' : ''}} {{todosBatchMode ? 'batch-item' : ''}} {{item.selected ? 'selected' : ''}}" bindtap="{{todosBatchMode ? 'toggleTodoSelect' : ''}}" data-id="{{item._id}}">
            <view class="batch-checkbox" wx:if="{{todosBatchMode}}">
              <view class="checkbox {{item.selected ? 'checked' : ''}}">
                <text wx:if="{{item.selected}}">✓</text>
              </view>
            </view>
            <view class="checkbox {{item.completed ? 'checked' : ''}}" bindtap="toggleTodo" data-item="{{item}}" wx:if="{{!todosBatchMode}}">
              <text wx:if="{{item.completed}}">✓</text>
            </view>
            <view class="todo-info">
              <view class="todo-text-wrapper">
                <block wx:for="{{item.contentSegments}}" wx:for-item="segment" wx:key="index">
                  <text wx:if="{{segment.type === 'text'}}" class="todo-text">{{segment.content}}</text>
                  <text wx:if="{{segment.type === 'link'}}" class="todo-text link" bindtap="openLink" data-url="{{segment.content}}">{{segment.content}}</text>
                  <image wx:if="{{segment.type === 'image'}}" class="todo-image" src="{{segment.src}}" mode="aspectFill" binderror="onTodoImageError" data-index="{{index}}" data-todo-id="{{item._id}}"></image>
                </block>
              </view>
              <text class="todo-time">{{item.createTimeStr}}</text>
            </view>
            <text class="todo-edit" bindtap="editTodo" data-item="{{item}}" wx:if="{{!todosBatchMode}}">编辑</text>
            <text class="todo-delete" bindtap="deleteTodo" data-id="{{item._id}}" wx:if="{{!todosBatchMode}}">删除</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>

<!-- Share Modal -->
<view class="modal {{shareShow ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closeShareModal"></view>
  <view class="modal-content">
    <view class="modal-header">设置分享密码</view>
    <view class="modal-body">
      <input type="text" placeholder="请输入4-6位分享密码" value="{{sharePassword}}" bindinput="onSharePasswordInput" bindblur="onSharePasswordInput" maxlength="6" />
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" type="button" bindtap="closeShareModal">取消</button>
      <button class="btn-confirm" type="button" bindtap="confirmShare">确定</button>
    </view>
  </view>
</view>

<!-- Todo Edit Modal -->
<view class="modal {{todoEditShow ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closeTodoEditModal"></view>
  <view class="modal-content">
    <view class="modal-header">编辑待办</view>
    <view class="modal-body">
      <input type="text" placeholder="请输入待办内容" value="{{editTodoContent}}" bindinput="onEditTodoInput" />
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeTodoEditModal">取消</button>
      <button class="btn-confirm" bindtap="confirmEditTodo">确定</button>
    </view>
  </view>
</view>

<!-- Note Preview Modal -->
<view class="modal {{showPreviewModal ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closePreviewModal"></view>
  <view class="modal-content preview-modal">
    <view class="modal-header">{{previewNote.title || '无标题'}}</view>
    <view class="modal-body preview-body">
      <scroll-view scroll-y class="preview-scroll">
        <view class="preview-content-full">
          <block wx:for="{{previewNote.parsedContent}}" wx:for-item="segment" wx:key="index">
            <!-- Line breaks -->
            <view wx:if="{{segment.type === 'br'}}" class="preview-br"></view>
            
            <!-- Headings -->
            <view wx:if="{{segment.type === 'heading'}}" class="preview-heading preview-heading-{{segment.level}}">
              <block wx:for="{{segment.content}}" wx:for-item="inline" wx:key="idx">
                <text wx:if="{{inline.type === 'text'}}" class="preview-heading-text">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'bold'}}" class="preview-bold preview-heading-text">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'italic'}}" class="preview-italic preview-heading-text">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'code'}}" class="preview-inline-code">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'link'}}" class="preview-link preview-heading-text" bindtap="openLink" data-url="{{inline.content}}">{{inline.content}}</text>
              </block>
            </view>
            
            <!-- List items -->
            <view wx:if="{{segment.type === 'list-item'}}" class="preview-list-item">
              <text wx:if="{{segment.listType === 'unordered'}}" class="preview-bullet">• </text>
              <text wx:if="{{segment.listType === 'ordered'}}" class="preview-number">{{segment.number}}. </text>
              <view class="preview-list-content">
                <block wx:for="{{segment.content}}" wx:for-item="inline" wx:key="idx">
                  <text wx:if="{{inline.type === 'text'}}" class="preview-list-text">{{inline.content}}</text>
                  <text wx:if="{{inline.type === 'bold'}}" class="preview-bold preview-list-text">{{inline.content}}</text>
                  <text wx:if="{{inline.type === 'italic'}}" class="preview-italic preview-list-text">{{inline.content}}</text>
                  <text wx:if="{{inline.type === 'code'}}" class="preview-inline-code">{{inline.content}}</text>
                  <text wx:if="{{inline.type === 'link'}}" class="preview-link preview-list-text" bindtap="openLink" data-url="{{inline.content}}">{{inline.content}}</text>
                </block>
              </view>
            </view>
            
            <!-- Paragraphs -->
            <view wx:if="{{segment.type === 'paragraph'}}" class="preview-paragraph">
              <block wx:for="{{segment.content}}" wx:for-item="inline" wx:key="idx">
                <text wx:if="{{inline.type === 'text'}}" class="preview-segment-text">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'bold'}}" class="preview-bold">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'italic'}}" class="preview-italic">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'code'}}" class="preview-inline-code">{{inline.content}}</text>
                <text wx:if="{{inline.type === 'link'}}" class="preview-segment-link" bindtap="openLink" data-url="{{inline.content}}">{{inline.content}}</text>
                <image wx:if="{{inline.type === 'image'}}" class="preview-segment-image" src="{{inline.src}}" mode="aspectFill" binderror="onPreviewImageError" bindtap="previewImage" data-src="{{inline.src}}"></image>
              </block>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closePreviewModal">关闭</button>
      <button class="btn-confirm" bindtap="editFromPreview">编辑</button>
    </view>
  </view>
</view>
