<view class="container">
  <view class="header">
    <view class="avatar-wrapper" bindtap="chooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl || '/static/icon/headPortrait.png'}}" mode="aspectFill"></image>
      <view class="avatar-mask">
        <text class="avatar-tip">更换头像</text>
      </view>
    </view>
    <view class="nickname-wrapper" bindtap="editNickname">
      <text class="nickname">{{userInfo.nickName || '用户'}}</text>
      <text class="edit-icon">✎</text>
    </view>
    <text class="openid">ID: {{userInfo.openid || '-'}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onLogout">
      <text class="icon">🚪</text>
      <text class="text">退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>

<!-- Edit Nickname Modal -->
<view class="modal {{showNicknameModal ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closeNicknameModal"></view>
  <view class="modal-content">
    <view class="modal-header">修改昵称</view>
    <view class="modal-body">
      <input type="text" placeholder="请输入昵称" value="{{newNickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeNicknameModal">取消</button>
      <button class="btn-confirm" bindtap="saveNickname">保存</button>
    </view>
  </view>
</view>
