.container {
  min-height: 100vh;
  background: #F8F8F8;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-wrapper:active .avatar-mask {
  opacity: 1;
}

.avatar-tip {
  color: #fff;
  font-size: 24rpx;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.edit-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 12rpx;
  padding: 4rpx;
}

.openid {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.menu-list {
  margin: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item .icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-item .text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-item .arrow {
  font-size: 32rpx;
  color: #999;
}

/* Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  transition: all 0.3s;
}

.modal.show .modal-content {
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
}

.modal-body {
  padding: 30rpx 40rpx;
}

.modal-body input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer button {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
  background: none;
  border: none;
  border-radius: 0;
}

.modal-footer button::after {
  border: none;
}

.btn-cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #667eea;
  font-weight: bold;
}
