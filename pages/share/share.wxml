<view class="container">
  <!-- Password Input -->
  <view wx:if="{{!verified}}" class="password-section">
    <view class="lock-icon">🔒</view>
    <text class="title">输入分享密码</text>
    <text class="subtitle">输入好友给你的分享密码查看小记</text>
    <input type="text" class="password-input" placeholder="请输入4-6位密码" value="{{password}}" bindinput="onPasswordInput" maxlength="6" />
    <button class="btn-verify" bindtap="verifyPassword" loading="{{loading}}">查看分享</button>
  </view>

  <!-- Shared Notes List -->
  <view wx:if="{{verified}}" class="notes-section">
    <view class="section-header">
      <text class="section-title">共享的小记</text>
      <text class="change-btn" bindtap="changePassword">更换密码</text>
    </view>

    <block wx:if="{{sharedNotes.length > 0}}">
      <view class="note-list">
        <view class="note-item" wx:for="{{sharedNotes}}" wx:key="_id" style="background: {{item.color || '#ffffff'}};">
          <text class="note-title">{{item.title || '无标题'}}</text>
          <text class="note-content">{{item.content}}</text>
          <view class="note-author-box">
            <image class="author-avatar-small" src="{{item.authorAvatar || '/static/icon/headPortrait.png'}}" mode="aspectFill"></image>
            <text class="note-author">{{item.authorName}}</text>
          </view>
          <text class="note-time">{{item.createTime}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty-state">
      <image src="/static/icon/empty_fill.png" mode="aspectFit"></image>
      <text>该密码下没有共享的小记</text>
    </view>
  </view>
</view>
