.container {
  min-height: 100vh;
  background: #F8F8F8;
  padding: 30rpx;
}

/* Group Header */
.group-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.group-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.group-title {
  font-size: 40rpx;
  font-weight: bold;
}

.edit-group-name {
  font-size: 26rpx;
  opacity: 0.8;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
}

.group-meta {
  display: flex;
  gap: 30rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

.group-meta text:last-child {
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* Members Section */
.members-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.members-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #e0e0e0;
}

.member-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.member-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.member-tag.creator {
  background: #e3f2fd;
  color: #1976d2;
}

/* Join Requests */
.join-requests-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.join-requests-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.join-requests-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff9800;
}

.join-requests-list {
  margin-top: 20rpx;
}

.join-request-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.join-request-item:last-child {
  border-bottom: none;
}

.request-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #e0e0e0;
}

.request-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.request-actions {
  display: flex;
  gap: 16rpx;
}

.approve-btn {
  padding: 8rpx 24rpx;
  background: #e8f5e9;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #4caf50;
}

.reject-btn {
  padding: 8rpx 24rpx;
  background: #ffebee;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #f44336;
}

.kick-btn {
  padding: 8rpx 20rpx;
  background: #ffebee;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #f44336;
}

/* Add Note Button */
.add-note-btn {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
}

.add-note-btn .icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.add-note-btn text:last-child {
  font-size: 30rpx;
  color: #667eea;
}

/* Section */
.section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #667eea;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.batch-trigger {
  font-size: 24rpx;
  color: #667eea;
  padding: 6rpx 16rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
}

.toggle-icon {
  font-size: 28rpx;
  color: #667eea;
  margin-right: 20rpx;
  font-weight: bold;
}

/* Batch Bar */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.batch-info {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 24rpx;
}

.batch-btn.delete {
  color: #f44336;
  background: #ffebee;
}

.batch-btn.cancel {
  color: #666;
  background: #f5f5f5;
}

/* Batch Checkbox */
.batch-checkbox {
  margin-right: 20rpx;
}

.batch-checkbox .checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.batch-checkbox .checkbox.checked {
  background: #667eea;
  border-color: #667eea;
}

.batch-checkbox .checkbox text {
  color: #fff;
  font-size: 28rpx;
}

.batch-item {
  display: flex;
  align-items: flex-start;
}

.note-item.selected,
.todo-item.selected {
  background: #f0f7ff !important;
}

.note-item.selected .batch-checkbox .checkbox,
.todo-item.selected .batch-checkbox .checkbox {
  background: #667eea;
  border-color: #667eea;
}

/* Note List */
.note-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.note-item {
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
  background: #fff;
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.note-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.note-delete {
  padding: 8rpx 20rpx;
  background: #ffebee;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #f44336;
}

.note-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
  position: relative;
  z-index: 1;
}

.note-content.collapsed {
  max-height: 4.8em;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  position: relative;
  z-index: 1;
}

.note-content-inner {
  display: block;
  position: relative;
  z-index: 1;
}

.note-text {
  word-break: break-all;
}

.note-text.link {
  color: #576b95;
  text-decoration: underline;
  word-break: break-all;
}

.note-expand {
  font-size: 24rpx;
  color: #667eea;
  margin-bottom: 12rpx;
  text-align: center;
}

.note-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.note-author {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  background: #e0e0e0;
}

.author-name {
  font-size: 24rpx;
  color: #666;
}

.note-time {
  font-size: 24rpx;
  color: #999;
}

.history-btn {
  padding: 4rpx 16rpx;
  background: #e3f2fd;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #2196f3;
  margin-left: 16rpx;
}

.history-btn-small {
  padding: 2rpx 12rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #2196f3;
  margin-left: 12rpx;
}

/* Todo List */
.todo-input-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.todo-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.todo-add-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
  margin-left: 20rpx;
}

.todo-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
  z-index: 1;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-item.completed .todo-text {
  text-decoration: line-through;
  color: #999;
}

.todo-item .checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.todo-item .checkbox.checked {
  background: #4caf50;
  border-color: #4caf50;
}

.todo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.todo-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.todo-text.collapsed {
  max-height: 2.4em;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.todo-content-inner {
  display: block;
  position: relative;
  z-index: 1;
}

.todo-content-text {
  word-break: break-all;
}

.todo-content-text.link {
  color: #576b95;
  text-decoration: underline;
  word-break: break-all;
}

.todo-expand {
  font-size: 22rpx;
  color: #667eea;
  margin-bottom: 8rpx;
  text-align: center;
}

.todo-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.todo-author-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.todo-author-name {
  font-size: 22rpx;
  color: #666;
}

.todo-time {
  font-size: 24rpx;
  color: #999;
}

.todo-delete {
  padding: 8rpx 20rpx;
  background: #ffebee;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #f44336;
}

/* Empty State */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Leave Button */
.leave-btn {
  margin-top: 60rpx;
  padding: 30rpx;
  text-align: center;
  color: #f44336;
  font-size: 30rpx;
}

/* Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: none;
  opacity: 0;
  transition: opacity 0.3s;
}

.modal.show {
  display: flex;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  margin: auto;
  transform: scale(0.9);
  width: 85%;
  background: #fff;
  border-radius: 20rpx;
  transition: transform 0.3s;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  padding: 40rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #f0f0f0;
  word-break: break-all;
}

.modal-body {
  padding: 40rpx;
}

.modal-body input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.modal-body textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.color-picker {
  margin-top: 10rpx;
}

.color-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.color-list {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
}

.color-item.selected {
  border-color: #667eea;
}

.color-item text {
  color: #333;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-footer button {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  background: none;
  border: none;
  font-size: 32rpx;
  padding: 0;
  margin: 0;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-footer button::after {
  border: none;
}

.btn-cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  color: #667eea;
  font-weight: bold;
}

/* History */
.history-body {
  max-height: 600rpx;
  overflow-y: auto;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.history-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.history-dot.create {
  background: #4caf50;
}

.history-dot.update {
  background: #2196f3;
}

.history-dot.complete {
  background: #ff9800;
}

.history-dot.uncomplete {
  background: #9e9e9e;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

/* Preview */
.preview-modal {
  /* No max-height to match home page modal style */
}

.preview-body {
  max-height: 50vh;
  display: flex;
  flex-direction: column;
}

.preview-scroll {
  height: 400rpx;
}

.preview-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  word-break: break-all;
  display: block;
  white-space: pre-wrap;
}

.preview-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.preview-author {
  display: flex;
  align-items: center;
}

.preview-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background: #e0e0e0;
}

.preview-time {
  font-size: 24rpx;
  color: #999;
}

/* Note Edit Full Screen */
.note-edit-full {
  width: 100vw;
  height: 100vh;
  max-height: 100vh;
  border-radius: 0;
  margin: 0;
  position: absolute;
  left: 0;
  top: 0;
  transform: none;
}

.modal.show .note-edit-full {
  transform: none;
}

.note-edit-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #F8F8F8;
}

.note-edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.note-edit-close {
  font-size: 30rpx;
  color: #666;
  padding: 10rpx;
}

.note-edit-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.note-edit-save {
  font-size: 30rpx;
  color: #667eea;
  font-weight: bold;
  padding: 10rpx;
}

.note-edit-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.note-edit-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.note-edit-title-input {
  font-size: 36rpx;
  font-weight: bold;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.note-edit-content-input {
  width: 100%;
  height: 400rpx;
  font-size: 32rpx;
  line-height: 1.8;
  padding: 20rpx 0;
}

.note-edit-word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.note-edit-color-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.note-edit-color-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.note-edit-colors {
  display: flex;
  gap: 20rpx;
}

.note-edit-color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.note-edit-color-item.active {
  box-shadow: 0 0 0 4rpx #667eea;
}

.note-edit-preview {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  min-height: 150rpx;
}

.note-edit-preview-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.note-edit-preview-content {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* Markdown Toolbar */
.markdown-toolbar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.tool-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.tool-btn.italic {
  font-style: italic;
}

.tool-btn:active {
  background: #e0e0e0;
}

/* Preview Content Wrapper */
.note-edit-preview-content-wrapper {
  max-height: 200rpx;
  overflow-y: auto;
}

.preview-placeholder {
  color: #999;
  font-size: 28rpx;
}

/* Markdown Styles in Preview */
.preview-br {
  height: 16rpx;
}

.preview-heading {
  margin-bottom: 16rpx;
  font-weight: bold;
  color: #333;
}

.preview-heading-1 {
  font-size: 40rpx;
}

.preview-heading-2 {
  font-size: 36rpx;
}

.preview-heading-3 {
  font-size: 32rpx;
}

.preview-list-item {
  display: flex;
  margin-bottom: 8rpx;
  padding-left: 12rpx;
}

.preview-bullet {
  color: #667eea;
  margin-right: 8rpx;
}

.preview-number {
  color: #667eea;
  margin-right: 8rpx;
}

.preview-paragraph {
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.preview-bold {
  font-weight: bold;
}

.preview-italic {
  font-style: italic;
}

.preview-inline-code {
  background: #f5f5f5;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  font-family: monospace;
  font-size: 26rpx;
  color: #e83e8c;
}

.preview-link {
  color: #576b95;
  text-decoration: underline;
}

.preview-inline-image,
.preview-image {
  width: 100%;
  max-height: 300rpx;
  border-radius: 8rpx;
  margin: 8rpx 0;
}

/* Markdown Preview Styles */
.md-paragraph {
  margin-bottom: 16rpx;
  line-height: 1.8;
  font-size: 30rpx;
  color: #333;
}

.md-heading {
  font-weight: bold;
  margin: 24rpx 0 16rpx 0;
  color: #333;
}

.md-h1 {
  font-size: 44rpx;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 16rpx;
}

.md-h2 {
  font-size: 38rpx;
}

.md-h3 {
  font-size: 34rpx;
}

.md-list-item {
  margin-bottom: 12rpx;
  line-height: 1.8;
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: flex-start;
}

.md-list-bullet {
  margin-right: 12rpx;
  color: #666;
}

.md-list-number {
  margin-right: 12rpx;
  color: #666;
  min-width: 40rpx;
}

.md-bold {
  font-weight: bold;
}

.md-italic {
  font-style: italic;
}

.md-code {
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-family: monospace;
  font-size: 26rpx;
  color: #e83e8c;
}

.md-link {
  color: #576b95;
  text-decoration: underline;
}

.md-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
  margin: 16rpx 0;
}

.md-br {
  height: 16rpx;
}
