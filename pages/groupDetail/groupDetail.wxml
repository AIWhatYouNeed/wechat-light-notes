<view class="container">
  <!-- Group Info -->
  <view class="group-header" wx:if="{{groupInfo}}">
    <view class="group-title">{{groupInfo.name}}</view>
    <view class="group-meta">
      <text>分享码：{{groupInfo.code}}</text>
      <text bindtap="toggleMembers">{{groupInfo.members.length}} 人 ></text>
    </view>
  </view>

  <!-- Members List -->
  <view class="members-section" wx:if="{{showMembers}}">
    <view class="members-title">成员列表</view>
    <view class="member-list">
      <view class="member-item" wx:for="{{groupInfo.members}}" wx:key="*this">
        <text class="member-name">用户 {{item.substring(0, 8)}}...</text>
        <text class="member-tag creator" wx:if="{{item === groupInfo.creator}}">创建者</text>
        <text class="kick-btn" wx:if="{{isCreator && item !== groupInfo.creator}}" bindtap="kickMember" data-openid="{{item}}">踢出</text>
      </view>
    </view>
  </view>

  <!-- Add Note Button -->
  <view class="add-note-btn" bindtap="showAddModal">
    <text class="icon">+</text>
    <text>记录新的共享小记</text>
  </view>

  <!-- Notes List -->
  <view class="section">
    <!-- Notes Batch Bar -->
    <view class="batch-bar" wx:if="{{notesBatchMode}}">
      <text class="batch-info">已选择 {{selectedNotes.length}} 项</text>
      <view class="batch-actions">
        <text class="batch-btn" bindtap="selectAllNotes">全选</text>
        <text class="batch-btn delete" bindtap="batchDeleteNotes">删除</text>
        <text class="batch-btn cancel" bindtap="exitNotesBatchMode">取消</text>
      </view>
    </view>

    <view class="section-title" bindtap="{{notesBatchMode ? '' : 'toggleNotes'}}">
      <text>共享小记</text>
      <view class="title-actions" wx:if="{{!notesBatchMode}}">
        <text class="batch-trigger" catchtap="enterNotesBatchMode">批量</text>
        <text class="toggle-icon">{{notesCollapsed ? '▶' : '▼'}}</text>
      </view>
    </view>
    <block wx:if="{{!notesCollapsed && notes.length > 0}}">
      <view class="note-list">
        <view class="note-item {{notesBatchMode ? 'batch-item' : ''}} {{item.selected ? 'selected' : ''}}" wx:for="{{notes}}" wx:key="_id" style="background: {{item.color}}" bindtap="{{notesBatchMode ? 'toggleNoteSelect' : 'showEditModal'}}" data-note="{{item}}" data-id="{{item._id}}">
          <view class="batch-checkbox" wx:if="{{notesBatchMode}}">
            <view class="checkbox {{item.selected ? 'checked' : ''}}">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
          <view class="note-header">
            <text class="note-title">{{item.title || '无标题'}}</text>
            <text class="note-delete" catchtap="deleteNote" data-id="{{item._id}}" wx:if="{{!notesBatchMode}}">删除</text>
          </view>
          <view class="note-content">{{item.content}}</view>
          <view class="note-footer">
            <text class="note-time">{{item.createTimeStr}}</text>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{!notesCollapsed && notes.length === 0}}" class="empty-state">
      <text>还没有共享小记，添加一条吧</text>
    </view>
  </view>

  <!-- Todos List -->
  <view class="section">
    <!-- Todos Batch Bar -->
    <view class="batch-bar" wx:if="{{todosBatchMode}}">
      <text class="batch-info">已选择 {{selectedTodos.length}} 项</text>
      <view class="batch-actions">
        <text class="batch-btn" bindtap="selectAllTodos">全选</text>
        <text class="batch-btn delete" bindtap="batchDeleteTodos">删除</text>
        <text class="batch-btn cancel" bindtap="exitTodosBatchMode">取消</text>
      </view>
    </view>

    <view class="section-title" bindtap="{{todosBatchMode ? '' : 'toggleTodos'}}">
      <text>共享待办</text>
      <view class="title-actions" wx:if="{{!todosBatchMode}}">
        <text class="batch-trigger" catchtap="enterTodosBatchMode">批量</text>
        <text class="toggle-icon">{{todosCollapsed ? '▶' : '▼'}}</text>
      </view>
    </view>
    <block wx:if="{{!todosCollapsed && !todosBatchMode}}">
      <view class="todo-input-box">
        <input class="todo-input" placeholder="添加新的共享待办..." value="{{newTodo}}" bindinput="onTodoInput" confirm-type="done" bindconfirm="addTodo" />
        <view class="todo-add-btn" bindtap="addTodo">+</view>
      </view>
    </block>
    <block wx:if="{{!todosCollapsed && todos.length > 0}}">
      <view class="todo-list">
        <view class="todo-item {{item.completed ? 'completed' : ''}} {{todosBatchMode ? 'batch-item' : ''}} {{item.selected ? 'selected' : ''}}" wx:for="{{todos}}" wx:key="_id" bindtap="{{todosBatchMode ? 'toggleTodoSelect' : ''}}" data-id="{{item._id}}">
          <view class="batch-checkbox" wx:if="{{todosBatchMode}}">
            <view class="checkbox {{item.selected ? 'checked' : ''}}">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
          <view class="checkbox {{item.completed ? 'checked' : ''}}" bindtap="toggleTodo" data-item="{{item}}" wx:if="{{!todosBatchMode}}">
            <text wx:if="{{item.completed}}">✓</text>
          </view>
          <view class="todo-info" bindtap="editTodo" data-item="{{item}}" wx:if="{{!todosBatchMode}}">
            <text class="todo-text">{{item.content}}</text>
            <text class="todo-time">{{item.createTimeStr}}</text>
          </view>
          <view class="todo-info" wx:if="{{todosBatchMode}}">
            <text class="todo-text">{{item.content}}</text>
            <text class="todo-time">{{item.createTimeStr}}</text>
          </view>
          <text class="todo-delete" bindtap="deleteTodo" data-id="{{item._id}}" wx:if="{{!todosBatchMode}}">删除</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!todosCollapsed && todos.length === 0}}" class="empty-state">
      <text>还没有共享待办，添加一条吧</text>
    </view>
  </view>

  <!-- Leave Group -->
  <view class="leave-btn" bindtap="leaveGroup">
    <text>退出共享组</text>
  </view>
</view>

<!-- Add Note Modal -->
<view class="modal {{showAddModal ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closeAddModal"></view>
  <view class="modal-content">
    <view class="modal-header">添加共享小记</view>
    <view class="modal-body">
      <input type="text" placeholder="标题（可选）" value="{{noteTitle}}" bindinput="onTitleInput" />
      <textarea placeholder="请输入内容" value="{{noteContent}}" bindinput="onContentInput" maxlength="500" />
      <view class="color-picker">
        <text class="color-label">选择背景色：</text>
        <view class="color-list">
          <view class="color-item {{selectedColor === item ? 'selected' : ''}}" wx:for="{{colors}}" wx:key="*this" style="background: {{item}}" bindtap="selectColor" data-color="{{item}}">
            <text wx:if="{{selectedColor === item}}">✓</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeAddModal">取消</button>
      <button class="btn-confirm" bindtap="addNote">添加</button>
    </view>
  </view>
</view>

<!-- Edit Note Modal -->
<view class="modal {{showEditModal ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closeEditModal"></view>
  <view class="modal-content">
    <view class="modal-header">编辑共享小记</view>
    <view class="modal-body">
      <input type="text" placeholder="标题（可选）" value="{{noteTitle}}" bindinput="onTitleInput" />
      <textarea placeholder="请输入内容" value="{{noteContent}}" bindinput="onContentInput" maxlength="500" />
      <view class="color-picker">
        <text class="color-label">选择背景色：</text>
        <view class="color-list">
          <view class="color-item {{selectedColor === item ? 'selected' : ''}}" wx:for="{{colors}}" wx:key="*this" style="background: {{item}}" bindtap="selectColor" data-color="{{item}}">
            <text wx:if="{{selectedColor === item}}">✓</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeEditModal">取消</button>
      <button class="btn-confirm" bindtap="updateNote">保存</button>
    </view>
  </view>
</view>

<!-- Edit Todo Modal -->
<view class="modal {{showTodoEditModal ? 'show' : ''}}">
  <view class="modal-mask" bindtap="closeTodoEditModal"></view>
  <view class="modal-content">
    <view class="modal-header">编辑待办</view>
    <view class="modal-body">
      <input type="text" placeholder="请输入待办内容" value="{{editTodoContent}}" bindinput="onEditTodoInput" />
    </view>
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeTodoEditModal">取消</button>
      <button class="btn-confirm" bindtap="confirmEditTodo">保存</button>
    </view>
  </view>
</view>
